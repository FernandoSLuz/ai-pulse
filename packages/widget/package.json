{
  "name": "@ai-pulse/widget",
  "version": "1.0.0-rc.4",
  "private": true,
  "description": "AI Pulse desktop app — tray, server supervisor, settings, and the leaderboard widget.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && node scripts/build-resources.mjs",
    "start": "electron dist/main.js",
    "dev": "npm run build && electron dist/main.js",
    "dist": "npm run build && electron-builder --win",
    "dist:ci": "npm run build && electron-builder --win --publish never",
    "dist:dir": "npm run build && electron-builder --win --dir"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "electron-updater": "^6.3.9",
    "node-notifier": "^10.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^22.10.5",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.2"
  }
}
