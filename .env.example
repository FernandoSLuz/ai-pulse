# AI Pulse — configuration.
#
# NOTE: In the packaged desktop app you don't need this file — set every key in
# the app's Settings window (they're stored in your user profile, not here).
# This .env is only for running the server directly during development.
#
# AI curation rotates across whichever of these cloud providers you configure.
# You only need ONE, but adding more makes curation more resilient: when one
# free tier is rate-limited, AI Pulse automatically falls through to the next.

# Gemini — best free quality; get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Cerebras — very generous + fast free tier; https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Groq — fast, but a small daily token budget; https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter — free model pool as extra spillover; https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Artificial Analysis — benchmark data; free key at https://artificialanalysis.ai/insights
AA_API_KEY=

# Tavily — preferred web-search agent for chat (1,000 free credits/month); https://app.tavily.com
TAVILY_API_KEY=

# Server
PORT=3847
AA_POLL_INTERVAL_MS=7200000
RSS_POLL_INTERVAL_MS=1200000
YT_POLL_INTERVAL_MS=1800000
